NODE_ENV=test
PORT=3000
LOG_LEVEL=info
DB_HOST=localhost
DB_PORT=5433
DB_USER=app
DB_PASSWORD=app
DB_NAME=cv_test

# Keep CORS explicit in all environments
CORS_ORIGINS=http://localhost:3001
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-Id
CORS_EXPOSED_HEADERS=X-Request-Id
CORS_CREDENTIALS=true
CORS_MAX_AGE_SECONDS=600

# Rate limiter
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=100

# HTTP policy
TRUST_PROXY=false
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=5000
REQUEST_BODY_LIMIT=1mb

# OpenTelemetry
OTEL_SERVICE_NAME=cv-api-test
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Admin write authorization
ADMIN_API_TOKEN=local-admin-token

# Feature flags (explicit, no defaults)
FEATURE_FLAGS=swagger_docs=true,rum_ingest=true
