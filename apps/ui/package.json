{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "node ../../node_modules/eslint/bin/eslint.js src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "i18n:pull": "node ./scripts/i18n-pull.mjs",
    "test:smoke": "playwright test -c playwright.config.mjs",
    "test:a11y": "playwright test -c playwright.config.mjs a11y.spec.mjs"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10.0.3",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
