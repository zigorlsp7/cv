#RUNTIME
TRUST_PROXY=false
SWAGGER_ENABLED=true
CORS_ORIGINS=http://localhost:3001

#DATABASE
POSTGRES_PASSWORD=SET_FROM_OPEN_BAO

#TOLGEE
TOLGEE_PROJECT_ID=2

#NOTIFICATIONS
NOTIFICATIONS_KAFKA_BROKERS=notifications-redpanda:9092
NOTIFICATIONS_EMAIL_TOPIC=notification.email.requested.v1

#OPENBAO
OPENBAO_TOKEN=CHANGE_ME_LOCAL_OPENBAO_TOKEN

#WEB_BUILD
NEXT_PUBLIC_API_BASE_URL=http://cv-api:3000
NEXT_PUBLIC_RELEASE=local

#DEPLOY_IMAGES
API_IMAGE=REQUIRED_SET_BY_DEPLOY
WEB_IMAGE=REQUIRED_SET_BY_DEPLOY
