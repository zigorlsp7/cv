{
  "name": "cv-web",
  "private": true,
  "version": "0.1.3",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prepare": "node ./scripts/prepare-husky.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:cov:api": "npm run test:cov -w @cv/api -- --watchman=false --ci",
    "test:int:api": "npm run test:int -w @cv/api -- --watchman=false --detectOpenHandles",
    "test:e2e:api": "npm run test:e2e -w @cv/api -- --watchman=false --detectOpenHandles",
    "test:a11y:web": "./scripts/precommit-web-a11y.sh",
    "ci:integration:local": "./scripts/precommit-integration-e2e.sh",
    "ci:quality:local": "npm run lint && npm run typecheck && npm run build && npm run test:cov:api",
    "precommit:checks": "npm run ci:quality:local && npm run ci:integration:local && npm run test:a11y:web",
    "audit": "npm audit --audit-level=high",
    "contract:gen:web": "node ./scripts/generate-api-contract.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "husky": "^9.1.7"
  }
}
